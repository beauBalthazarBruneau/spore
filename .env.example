# ─── Spore environment variables ────────────────────────────────────────────
# Copy this file to .env at the repo root.
# For frontend-specific overrides, also copy it to frontend/.env.local.

# Required for all agent/scoring steps (LLM scoring, skills, orchestrator).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the SQLite database file path.
# Default: data/autoapply.db (relative to repo root).
# Useful for pointing at a separate DB during testing or CI.
# AUTOAPPLY_DB=data/autoapply.db

# Optional: frontend dev server port.
# Default: 3100
# PORT=3100
